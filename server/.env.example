# ── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
# Comma-separated list of allowed CORS origins.
CLIENT_ORIGIN=http://localhost:3000

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ── Database (MongoDB) ────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/toggledrive

# ── File storage ──────────────────────────────────────────
# Storage driver. Currently only "local" is implemented. An S3 driver can be
# added later without touching the rest of the codebase.
STORAGE_DRIVER=local
# Directory on disk where uploaded files are kept (local driver only).
STORAGE_DIR=./storage
# Public base URL used when building download links. Leave empty for relative
# URLs (works when the API and client share an origin / dev proxy).
PUBLIC_API_URL=

# ── Limits ────────────────────────────────────────────────
# Default per-user storage quota in bytes (default 5 GB).
DEFAULT_STORAGE_QUOTA=5368709120
# Max single upload size in bytes (default 100 MB).
MAX_UPLOAD_SIZE=104857600
